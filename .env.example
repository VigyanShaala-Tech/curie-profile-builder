# Use development for local `npm run dev` (production cookies/static only after `npm run build`).
NODE_ENV=development
PORT=8505
JWT_SECRET=replace-with-strong-secret

# Restrict HTTP clients to private addresses (loopback, LAN RFC1918, link-local, IPv6 ULA).
# When unset: enabled for NODE_ENV !== production; production accepts all unless set to true.
# PRIVATE_NETWORK_ONLY=false

# Optional: SQLite file (default: app.db next to server). Use if cwd/sync causes locks or missing DB.
# SQLITE_DB_PATH=C:\Temp\curie-profile-builder.db

# Google Sheets integration (required only if you want profile export)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=
